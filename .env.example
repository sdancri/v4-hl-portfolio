# =============================================================================
# V4_HL portfolio bot — Environment variables (Portainer Stack / docker compose)
# =============================================================================
# Multi-strategy pe Hyperliquid, 3 perechi (shared equity pool, compound):
#   BTC (bb_mr) / TIA (hi) / NEAR (hi) — vezi compose.V4_HL.yml.
#
# Acest fisier = sursa unica pt sectiunea Portainer "Environment variables".
# In Portainer: buton "Load variables from .env file" → incarci acest fisier
# completat, apoi editezi secretele. compose.V4_HL.yml refera fiecare ${VAR}
# de aici — daca lipseste una, container-ul primeste valoarea default (sau
# goala daca nu are default).
#
# NU comite .env real (doar .env.example). Cheia agent semneaza ordere.
# =============================================================================

# --- REQUIRED — Wallet auth (subaccount V4_HL, wallet separat) --------------
# HL_MAIN_ADDRESS      = adresa Rabby cu USDC pe HL (read-only). Fondurile se
#                        adauga manual pe HL; botul doar citeste equity-ul.
# HL_AGENT_PRIVATE_KEY = cheia agent generata pe HL UI (trade-only — NU poate
#                        retrage fonduri). EXPIRA la 180 zile — vezi
#                        AGENT_EXPIRY_WARN_DAYS mai jos.
HL_MAIN_ADDRESS=0xYOUR_RABBY_ADDRESS
HL_AGENT_PRIVATE_KEY=0xYOUR_AGENT_PRIVATE_KEY
HL_AGENT_ADDRESS=                   # optional sanity check (gol = skip)

# --- OPTIONAL — Hyperliquid endpoints (gol = mainnet default) ---------------
# Testnet: HL_BASE_URL=https://api.hyperliquid-testnet.xyz
#          HL_WS_URL=wss://api.hyperliquid-testnet.xyz/ws
HL_BASE_URL=
HL_WS_URL=
# Override explicit pt chain ID EIP-712 (mainnet|testnet). Gol → fallback pe
# heuristica substring "testnet" in HL_BASE_URL. Seteaza explicit daca
# HL_BASE_URL e un URL custom/proxy fara "testnet" in string.
HL_NETWORK=

# --- OPTIONAL — HL agent expiry (cheia agent expira la 180 zile) -----------
AGENT_EXPIRY_WARN_DAYS=14
AGENT_EXPIRY_CHECK_INTERVAL_SEC=86400

# --- OPTIONAL — Telegram notifications --------------------------------------
# Lasa goale pentru a dezactiva Telegram (botul merge fara probleme).
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# --- OPTIONAL — Branding & display -------------------------------------------
CHART_TZ=Europe/Bucharest
BOT_VERSION=                         # ex "v1.3 fix SL" sau git short SHA (linie pe chart)

# --- OPTIONAL — Dashboard control / reset -------------------------------------
# RESET_TOKEN partajat cu dashboard-ul agregat (vezi endpoints /api/pause|resume|stop).
RESET_TOKEN=
# BOT_CONTROL_URL = http://<container_name>:<chart_port>, default OK daca botul
# ruleaza pe reteaua Docker `bots` (DNS intern). Override doar daca ai alt setup.
BOT_CONTROL_URL=http://V4_HL:8204
BOT_REPORTER_DB=/dashboard/state.db
BOT_REPORTER_HEARTBEAT_SEC=30

# --- OPTIONAL — Bind chart (Tailscale) ----------------------------------------
# IP-ul VPS in tailnet (`tailscale ip -4`). Chart-ul se leaga DOAR pe acest IP
# → accesibil prin Tailscale, NU public. Pt expunere publica: 0.0.0.0.
TAILSCALE_IP=100.92.198.95

# --- OPTIONAL — Rate limiter -------------------------------------------------
RATE_LIMIT_PER_SEC=5
RATE_LIMIT_BURST=10

# --- OPTIONAL — WS zombie watchdog --------------------------------------------
WS_ZOMBIE_TIMEOUT=90

# --- OPTIONAL — Memory monitor -------------------------------------------------
MEM_MON_INTERVAL_SEC=300
MEM_MON_RSS_ALERT_MB=320

# --- OPTIONAL — PnL fallback ---------------------------------------------------
# Taker fee rate pt fallback PnL (cand HL closed-pnl nu se indexeaza).
TAKER_FEE_RATE=0.00045
