# =============================================================================
# BP_HyperLiquid — Portainer Stack Environment variables
# =============================================================================
# Acest fisier = sursa unica pt sectiunea Portainer "Environment variables".
# In Portainer: buton "Load variables from .env file" → incarci acest fisier
# completat, apoi editezi secretele. docker-compose.yml referentiaza fiecare
# ${VAR} de aici — daca lipseste una, container-ul primeste valoare GOALA.
#
# NU comite .env real (doar .env.example). Cheia agent semneaza ordere.
# =============================================================================

# --- Compose structural ------------------------------------------------------
BOT_IMAGE=sdancri/trading-bot-hl:latest
MEM_LIMIT=384m
MEMSWAP_LIMIT=512m

# --- Identitate bot ----------------------------------------------------------
BOT_NAME=trading-bot-hl
SYMBOL=BTC                          # HL perp coin (NU "BTCUSDT" — doar coin)
STRATEGY_NAME=example
STRATEGY_MODULE=strategies.example_strategy
STRATEGY_CLASS=ExampleStrategy

# --- Chart / runtime ---------------------------------------------------------
CHART_PORT=9091                     # UNIC per bot pe VPS (nu se suprapune)
# IP-ul VPS in tailnet (`tailscale ip -4`). Chart-ul se leaga DOAR pe acest IP
# → accesibil prin Tailscale, NU public. Pt expunere publica: 0.0.0.0.
TAILSCALE_IP=100.92.198.95
CHART_TZ=Europe/Bucharest
TZ=Europe/Bucharest

# --- Risk / sizing -----------------------------------------------------------
ACCOUNT_SIZE=100.0                  # USDC referinta initiala (return% se calc de aici)
RESET_TOKEN=                        # token partajat control endpoints (vezi BP)
RISK_PCT=10
LEVERAGE_MAX=10
SL_MIN_PCT=0.5
SL_MAX_PCT=5.0

# --- Hyperliquid endpoints ---------------------------------------------------
# Mainnet: https://api.hyperliquid.xyz / wss://api.hyperliquid.xyz/ws
# Testnet: https://api.hyperliquid-testnet.xyz / wss://api.hyperliquid-testnet.xyz/ws
HL_BASE_URL=https://api.hyperliquid.xyz
HL_WS_URL=wss://api.hyperliquid.xyz/ws

# --- Wallet auth (DOAR 2 obligatorii) ----------------------------------------
# HL_MAIN_ADDRESS      = adresa Rabby cu USDC pe HL (read-only). TU adaugi
#                        fondurile manual pe HL; botul doar citeste equity-ul.
# HL_AGENT_PRIVATE_KEY = cheia agent generata pe HL UI (trade-only — NU poate
#                        retrage fonduri). Vezi scripts/gen_agent.py.
HL_MAIN_ADDRESS=0xYOUR_RABBY_ADDRESS
HL_AGENT_PRIVATE_KEY=0xYOUR_AGENT_PRIVATE_KEY
HL_AGENT_ADDRESS=                   # optional sanity check (gol = skip)

# --- HL instrument / WS ------------------------------------------------------
WS_KLINE_INTERVAL=30                # BP format (minute string); → HL "30m" intern
WS_ZOMBIE_TIMEOUT=60
QTY_STEP=0.0001
QTY_PRECISION=4
PRICE_PRECISION=2
RATE_LIMIT_PER_SEC=5
RATE_LIMIT_BURST=10

# --- HL agent expiry (cheia agent expira la 180 zile) ------------------------
AGENT_EXPIRY_WARN_DAYS=14
AGENT_EXPIRY_CHECK_INTERVAL_SEC=86400

# --- Memory monitor ----------------------------------------------------------
MEM_MON_INTERVAL_SEC=300
MEM_MON_RSS_ALERT_MB=320

# --- Dashboard (acelasi aggregator ca botii Bybit) ---------------------------
BOT_DASHBOARD_DIR=/dashboard            # path INTERN in container (env pt bot)
BOT_DASHBOARD_DIR_HOST=/srv/bots/dashboard  # path pe HOST (volume mount source)
BOT_REPORTER_DB=/dashboard/state.db
BOT_REPORTER_HEARTBEAT_SEC=30
BOT_CONTROL_URL=http://trading-bot-hl:9091  # = http://<BOT_NAME>:<CHART_PORT>
BOT_VERSION=

# --- Persistenta state -------------------------------------------------------
# Path pe HOST pt bot_state.json. Absolut, decuplat de stack working dir
# (ex /srv/bots/<BOT_NAME>/data). Portainer nu-l atinge la redeploy/edit/GC.
BOT_DATA_DIR=/srv/bots/trading-bot-hl/data

# --- Telegram ----------------------------------------------------------------
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
